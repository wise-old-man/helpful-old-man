# Bot token used to connect to Discord
HOM_DISCORD_TOKEN=abc123

# The ID of the channel where tickets are created from
HOM_SUPPORT_CHANNEL=456

# The ID of the channel where flags are changed
HOM_FLAG_CHANNEL=321

# The ID of the category tickets should be created in
HOM_TICKET_CATEGORY=789

# The ID of the moderator role
HOM_MOD_ROLE=101

# The ID of the group leaders role
HOM_GROUP_LEADER_ROLE=505

# The ID of the channel to send ticket logs to
HOM_MOD_LOG_CHANNEL=202

# The ID of the general questions channel
HOM_QUESTIONS_CHANNEL=303

# The channel where patreon benefits can be claimed
HOM_PATREON_CHANNEL=699

# Base URL for the API to assist with local dev, https://api.wiseoldman.net/v2 for production
HOM_DISCORD_BOT_BASE_API_URL=http://localhost:5000

# Base URL for the website to assist with local dev, https://wiseoldman.net for production
HOM_DISCORD_BOT_BASE_WEBSITE_URL=http://localhost:3000

# Master key for HOM so we don't hit rate limits, placeholder API key here 
# will break things. Either generate the API key or leave blank if developing
HOM_API_KEY=

# Admin password for mod related API requests
SHARED_ADMIN_PASSWORD=example123

# Optional GitHub issue integration
# Comma-separated repo list shown in the slash command and context-menu modal
# For production: wise-old-man/wise-old-man,wise-old-man/wiseoldman-discord-bot,wise-old-man/wiseoldman-runelite-plugin,wise-old-man/helpful-old-man
HOM_GITHUB_REPOSITORIES=

# Use a dedicated fine-grained token or machine user token with Issues write access only
# Visit https://github.com/settings/personal-access-tokens/new and select all repositories
#   listed in HOM_GITHUB_REPOSITORIES and under permission, "+ Add Permissions" choose: "Issues:Read and Write" 
HOM_GITHUB_TOKEN=
